{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm ci --legacy-peer-deps",
  "devCommand": "npm run dev",
  "crons": [
    {
      "path": "/api/cron/assistant-briefing",
      "schedule": "30 1 * * *"
    },
    {
      "path": "/api/cron/assistant-alerts",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/assistant-digest",
      "schedule": "0 3 * * 1"
    },
    {
      "path": "/api/notifications/schedule-followups",
      "schedule": "0 2 * * *"
    }
  ]
}
