# E2E Test Environment Variables
#
# These credentials are used by Playwright to authenticate test users.
# Copy this file to `.env` and fill in with actual test user credentials.
#
# Test users must exist in your database with the following characteristics:
# - TEST_ADMIN: An admin user with incomplete onboarding (onboarding_step < 2)
# - TEST_CLIENT: A client user
# - TEST_DRIVER: A driver user
# - TEST_SUPER_ADMIN: A super admin user
#
# To create a test admin user:
# 1. Register a new user via the app at http://localhost:3000/auth
# 2. Use the credentials below
# 3. Make sure the user's onboarding_step is set to 0 or 1 in the database

# Test Admin User (for onboarding wizard tests)
# This user should have onboarding_step < 2 to see the onboarding wizard
TEST_ADMIN_EMAIL=test-admin@example.com
TEST_ADMIN_PASSWORD=testpassword123

# Test Client User
TEST_CLIENT_EMAIL=test-client@example.com
TEST_CLIENT_PASSWORD=testpassword123

# Test Driver User
TEST_DRIVER_EMAIL=test-driver@example.com
TEST_DRIVER_PASSWORD=testpassword123

# Test Super Admin User
TEST_SUPER_ADMIN_EMAIL=test-superadmin@example.com
TEST_SUPER_ADMIN_PASSWORD=testpassword123

# Playwright Configuration (optional)
# Uncomment to override defaults
# PLAYWRIGHT_BASE_URL=http://localhost:3000
# BASE_URL=http://localhost:3000
