# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role (server-side only - keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
ALLOW_SUPABASE_DEV_FALLBACK=false

# Development integration toggles
# In development these default to disabled unless explicitly enabled.
# ALLOW_SUPABASE_DEV_FALLBACK=true
# ENABLE_MOCK_ENDPOINTS=false
# ENABLE_PAYMENTS_INTEGRATION=true
# ENABLE_EMAIL_INTEGRATION=true
# ENABLE_WHATSAPP_INTEGRATION=true

# OpenAI / Groq (AI features)
OPENAI_API_KEY=your-openai-api-key
GROQ_API_KEY=your-groq-api-key

# Google OAuth (optional - for Google Sign In)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_REDIRECT_URI=https://your-app.vercel.app/api/social/oauth/callback

# Google Gemini AI (for itinerary generation and AI tour import)
GOOGLE_GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_KEY=your-gemini-api-key

# Mapbox API (for geocoding and maps) - 100k free requests/month
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-access-token

# WhatsApp — WPPConnect sidecar (self-hosted, QR-based login)
WPPCONNECT_URL=https://travel-suite-waha.fly.dev
WHATSAPP_API_KEY=your-wppconnect-secret-key
WPPCONNECT_WEBHOOK_SECRET=your-wppconnect-webhook-secret

# WhatsApp — Meta Cloud API (optional, for template messages)
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_TOKEN=your-whatsapp-cloud-api-token
WHATSAPP_PHONE_ID=your-whatsapp-phone-number-id
WHATSAPP_APP_SECRET=your-meta-app-secret
# Non-production override only (ignored in production)
# WHATSAPP_ALLOW_UNSIGNED_WEBHOOK=false

# Notification queue processing hardening
# Each cron job has its own secret to limit blast radius if one leaks.
# ADMIN_CRON_SECRET        → used by /api/admin/* cron endpoints (e.g. operator-scorecards)
# NOTIFICATION_CRON_SECRET → used by /api/notifications/process-queue, retry-failed
# NOTIFICATION_QUEUE_CRON_SECRET → alias for NOTIFICATION_CRON_SECRET (backward compat)
# LOCATION_CLEANUP_CRON_SECRET   → used by /api/location/cleanup-expired
# CRON_SIGNING_SECRET      → used by /api/cron/* assistant jobs (HMAC-signed payloads)
# CRON_SECRET              → fallback shared secret for uncategorized cron endpoints
ADMIN_CRON_SECRET=your-admin-cron-secret
ADMIN_MUTATION_CSRF_TOKEN=your-admin-csrf-token
NOTIFICATION_CRON_SECRET=your-queue-cron-secret
NOTIFICATION_QUEUE_CRON_SECRET=your-queue-cron-secret
LOCATION_CLEANUP_CRON_SECRET=your-location-cleanup-secret
CRON_SIGNING_SECRET=your-cron-signing-secret
CRON_SECRET=your-shared-cron-secret
INTERNAL_API_KEY=your-internal-api-key
# NOTIFICATION_QUEUE_MAX_ATTEMPTS=5
# NOTIFICATION_QUEUE_BACKOFF_BASE_MINUTES=5
# NOTIFICATION_QUEUE_BACKOFF_MAX_MINUTES=60
# HEALTH_PENDING_QUEUE_THRESHOLD=100
# HEALTH_DEAD_LETTER_THRESHOLD=20
# HEALTH_OLDEST_PENDING_THRESHOLD_MINUTES=30

# App URL (for OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Payment / Billing (Razorpay)
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
GST_COMPANY_STATE=MAHARASHTRA

# Media / Search providers
PIXABAY_API_KEY=your-pixabay-api-key

# FAL.ai (AI image generation for Social Studio posters)
FAL_KEY=your-fal-api-key

# Outbound email (proposal PDFs and transactional)
RESEND_API_KEY=re_xxxxx
PROPOSAL_FROM_EMAIL=proposals@yourdomain.com
WELCOME_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_EMAIL=ops@yourdomain.com
SUPPORT_EMAIL=support@yourdomain.com

# Internal diagnostics
HEALTHCHECK_TOKEN=your-healthcheck-token
SOCIAL_OAUTH_STATE_SECRET=your-social-oauth-state-secret
SOCIAL_TOKEN_ENCRYPTION_KEY=your-32-byte-hex-or-base64-key
NEXTAUTH_SECRET=your-nextauth-secret

# Optional: Analytics
# NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Optional: Sentry (error tracking)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ORG=your-sentry-org-slug
# SENTRY_PROJECT=your-sentry-project-slug
# SENTRY_AUTH_TOKEN=your-sentry-auth-token
