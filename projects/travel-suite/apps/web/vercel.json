{
  "framework": "nextjs",
  "buildCommand": "NEXT_PRIVATE_SKIP_CACHE=1 npm run build",
  "installCommand": "npm ci --legacy-peer-deps",
  "devCommand": "npm run dev",
  "crons": [
    {
      "path": "/api/cron/assistant-briefing",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/automation-processor",
      "schedule": "0 2 * * *"
    }
  ]
}
