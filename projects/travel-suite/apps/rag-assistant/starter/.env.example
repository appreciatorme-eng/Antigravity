# RAG provider: use "pgvector" to reuse the existing Supabase DB
# or "pinecone" for an external vector store
RAG_PROVIDER=pgvector
RAG_VECTOR_INDEX=travel-suite-faq
RAG_EMBED_MODEL=text-embedding-3-small
RAG_CHAT_MODEL=gpt-4.1-mini
RAG_MAX_CHUNKS=6
RAG_CONFIRM_WORD=yes

# Required when RAG_PROVIDER=pgvector (reuse existing Supabase instance)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required when RAG_PROVIDER=pinecone
# PINECONE_API_KEY=your-pinecone-key

# WhatsApp (same keys used by apps/web)
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_ID=your-phone-number-id
WHATSAPP_APP_SECRET=your-app-secret
WHATSAPP_VERIFY_TOKEN=your-verify-token
